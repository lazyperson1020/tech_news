# Django Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# ==============================================
# LLM & NEWS CONFIGURATION (Optional)
# ==============================================
# The app works without these keys, but won't have:
# - AI-powered article summaries (needs OPENAI_API_KEY)
# - Live tech news fetching (needs NEWS_API_KEY)
# - Backup news source (needs TAVILY_API_KEY)

# 1. OpenAI API (for AI summaries)
# Get key: https://platform.openai.com/api-keys
# Cost: ~$0.002 per summary (very cheap)
# Example: OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
OPENAI_API_KEY=

# 2. NewsAPI (for live tech news)
# Get key: https://newsapi.org
# Free: 100 requests/day
# Example: NEWS_API_KEY=xxxxxxxxxxxxx
NEWS_API_KEY=

# 3. Tavily API (backup news source)
# Get key: https://tavily.com
# Free: unlimited requests
# Example: TAVILY_API_KEY=xxxxxxxxxxxxx
TAVILY_API_KEY=

# ==============================================
# DATABASE (SQLite for development)
# ==============================================
# Development uses SQLite by default (db.sqlite3)
# No setup needed for development!

# For production PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=siliconpost
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# ==============================================
# CACHING (Optional)
# ==============================================
# Development uses local memory cache
# No setup needed!

# For production Redis:
# CACHE_TYPE=redis
# REDIS_URL=redis://127.0.0.1:6379/1
